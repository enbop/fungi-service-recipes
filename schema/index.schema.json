{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Fungi Service Recipes Index",
  "type": "object",
  "required": ["schemaVersion", "name", "stability", "recipes"],
  "properties": {
    "schemaVersion": { "type": "integer", "minimum": 1 },
    "name": { "type": "string" },
    "description": { "type": "string" },
    "stability": { "type": "string", "enum": ["experimental"] },
    "recipes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "runtime", "manifestPath", "manifestAsset", "tags", "stability"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "runtime": { "type": "string" },
          "manifestPath": { "type": "string" },
          "manifestAsset": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*\\.manifest\\.yaml$" },
          "readmeAsset": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*\\.README\\.md$" },
          "homepage": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "stability": { "type": "string", "enum": ["experimental"] }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
