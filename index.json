{
  "schemaVersion": 1,
  "name": "fungi-service-recipes",
  "description": "Experimental Fungi service manifest recipes.",
  "stability": "experimental",
  "recipes": [
    {
      "id": "code-server",
      "name": "code-server",
      "description": "Browser-based VS Code served through the Docker-compatible runtime.",
      "runtime": "docker",
      "manifestPath": "recipes/code-server/manifest.yaml",
      "manifestAsset": "code-server.manifest.yaml",
      "readmeAsset": "code-server.README.md",
      "homepage": "https://github.com/coder/code-server",
      "tags": ["code", "editor", "web", "docker"],
      "stability": "experimental"
    },
    {
      "id": "filebrowser-lite",
      "name": "File Browser Lite",
      "description": "A lightweight File Browser build served as a Wasmtime-compatible WASI component.",
      "runtime": "wasmtime",
      "manifestPath": "recipes/filebrowser-lite/manifest.yaml",
      "manifestAsset": "filebrowser-lite.manifest.yaml",
      "readmeAsset": "filebrowser-lite.README.md",
      "homepage": "https://github.com/enbop/filebrowser-lite",
      "tags": ["files", "web", "wasi", "wasmtime"],
      "stability": "experimental"
    },
    {
      "id": "ssh-tunnel",
      "name": "SSH Tunnel",
      "description": "Expose an existing local SSH daemon on a target device as a Fungi TCP tunnel service.",
      "runtime": "tcp",
      "manifestPath": "recipes/ssh-tunnel/manifest.yaml",
      "manifestAsset": "ssh-tunnel.manifest.yaml",
      "readmeAsset": "ssh-tunnel.README.md",
      "homepage": "https://www.openssh.com/",
      "tags": ["ssh", "tcp", "tunnel"],
      "stability": "experimental"
    },
    {
      "id": "webdav",
      "name": "WebDAV",
      "description": "A WebDAV server served as a Wasmtime-compatible WASI component.",
      "runtime": "wasmtime",
      "manifestPath": "recipes/webdav/manifest.yaml",
      "manifestAsset": "webdav.manifest.yaml",
      "readmeAsset": "webdav.README.md",
      "homepage": "https://github.com/enbop/webdav-wasi",
      "tags": ["files", "webdav", "tcp", "wasi", "wasmtime"],
      "stability": "experimental"
    }
  ]
}
